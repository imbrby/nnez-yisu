<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="11dp"
    android:paddingEnd="8dp"
    android:paddingBottom="11dp">

    <TextView
        android:id="@+id/tv_category_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:text="地点分类"
        android:textColor="#FF174F43"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/category_meal_tile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_category_pine_meal"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="2dp">

            <ImageView
                android:id="@+id/category_meal_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="正餐"
                android:src="@drawable/ic_widget_meal" />

            <TextView
                android:id="@+id/category_meal_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="正餐"
                android:textColor="#FF174F43"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/category_meal_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="¥0.00"
                android:textColor="#FF174F43"
                android:textSize="8sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/category_drink_tile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="3dp"
            android:layout_weight="1"
            android:background="@drawable/widget_category_pine_drink"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="2dp">

            <ImageView
                android:id="@+id/category_drink_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="饮品"
                android:src="@drawable/ic_widget_drink" />

            <TextView
                android:id="@+id/category_drink_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="饮品"
                android:textColor="#FF8A651A"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/category_drink_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="¥0.00"
                android:textColor="#FF8A651A"
                android:textSize="8sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/category_snack_tile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="3dp"
            android:layout_weight="1"
            android:background="@drawable/widget_category_pine_snack"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="2dp">

            <ImageView
                android:id="@+id/category_snack_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="小吃"
                android:src="@drawable/ic_widget_snack" />

            <TextView
                android:id="@+id/category_snack_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="小吃"
                android:textColor="#FF9A5A32"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/category_snack_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="¥0.00"
                android:textColor="#FF9A5A32"
                android:textSize="8sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
