<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:paddingStart="15dp"
    android:paddingTop="12dp"
    android:paddingEnd="15dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_accent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="#FFC99B3C"
            android:textSize="8sp" />

        <TextView
            android:id="@+id/tv_recent_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:text="最近记录"
            android:textColor="#FF174F43"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_updated_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="等待同步"
            android:textColor="#FF557069"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_month_recharge_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="充值"
                android:textColor="#FF557069"
                android:textSize="9sp" />
            <TextView
                android:id="@+id/tv_month_recharge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="¥0.00"
                android:textColor="#FF174F43"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_month_expense_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="消费"
                android:textColor="#FF557069"
                android:textSize="9sp" />
            <TextView
                android:id="@+id/tv_month_expense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="¥0.00"
                android:textColor="#FF174F43"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="0.8"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_month_count_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="记录"
                android:textColor="#FF557069"
                android:textSize="9sp" />
            <TextView
                android:id="@+id/tv_month_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="0条"
                android:textColor="#FF174F43"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/recent_rule"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="7dp"
        android:background="#33708076" />

    <LinearLayout
        android:id="@+id/recent_records"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="3dp"
        android:layout_weight="1"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/recent_row_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/recent_icon_1"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/widget_category_pine_meal"
                android:contentDescription="交易分类"
                android:padding="5dp"
                android:src="@drawable/ic_widget_receipt" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/recent_title_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="暂无记录"
                    android:textColor="#FF174F43"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/recent_subtitle_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="--/-- --:--"
                    android:textColor="#FF557069"
                    android:textSize="9sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/recent_amount_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif"
                android:text="-¥0.00"
                android:textColor="#FFB5453E"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/recent_row_2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/recent_icon_2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/widget_category_pine_meal"
                android:contentDescription="交易分类"
                android:padding="5dp"
                android:src="@drawable/ic_widget_receipt" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/recent_title_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="暂无记录"
                    android:textColor="#FF174F43"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/recent_subtitle_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="--/-- --:--"
                    android:textColor="#FF557069"
                    android:textSize="9sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/recent_amount_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif"
                android:text="-¥0.00"
                android:textColor="#FFB5453E"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/recent_row_3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/recent_icon_3"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/widget_category_pine_meal"
                android:contentDescription="交易分类"
                android:padding="5dp"
                android:src="@drawable/ic_widget_receipt" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/recent_title_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="暂无记录"
                    android:textColor="#FF174F43"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/recent_subtitle_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="--/-- --:--"
                    android:textColor="#FF557069"
                    android:textSize="9sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/recent_amount_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif"
                android:text="-¥0.00"
                android:textColor="#FFB5453E"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/recent_row_4"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/recent_icon_4"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/widget_category_pine_meal"
                android:contentDescription="交易分类"
                android:padding="5dp"
                android:src="@drawable/ic_widget_receipt" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/recent_title_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="暂无记录"
                    android:textColor="#FF174F43"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/recent_subtitle_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="--/-- --:--"
                    android:textColor="#FF557069"
                    android:textSize="9sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/recent_amount_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif"
                android:text="-¥0.00"
                android:textColor="#FFB5453E"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
